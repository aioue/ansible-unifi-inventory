# UniFi Dynamic Inventory Environment Variables
# Copy to .env and customize, or export these in your shell

# UniFi controller URL (required)
UNIFI_URL=https://192.168.1.1

# Authentication: provide either UNIFI_TOKEN or both username and password
# Token authentication is preferred

# Local API token (preferred)
UNIFI_TOKEN=

# Username/password (alternative)
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your-password-here

# Site name (default: default)
UNIFI_SITE=default

# SSL verification (default: true)
# Set to false for self-signed certificates
UNIFI_VERIFY_SSL=true

# Include devices (APs, switches, gateways) in inventory (default: false)
UNIFI_INCLUDE_DEVICES=false

# Client last_seen filter in minutes (default: 30)
# Only include clients seen within this threshold
UNIFI_LAST_SEEN_MINUTES=30

# Cache TTL in seconds (default: 30)
# Set to 0 to disable caching
UNIFI_CACHE_TTL=30

# Cache file path
UNIFI_CACHE_PATH=./.cache/unifi_inventory.json

